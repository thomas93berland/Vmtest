rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && userDoc().data.isAdmin == true;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if signedIn();

      allow create: if isOwner(uid)
        && request.resource.data.coins == 5000
        && request.resource.data.isAdmin == false;

      // Testing/demo: sjakkrommet oppdaterer ELO for begge spillere etter ferdig parti.
      // Dette kan strammes inn senere med Cloud Functions.
      allow update: if signedIn()
        && request.resource.data.isAdmin == resource.data.isAdmin;

      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /bets/{betId} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.stake <= 500
        && request.resource.data.stake >= 10
        && request.resource.data.status == "Aktiv";

      allow update, delete: if isAdmin();
    }

    match /forumPosts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /chatMessages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /chessGames/{gameId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
